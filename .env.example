# Supabase Configuration
# Note: Vercel integration provides SUPABASE_URL and SUPABASE_ANON_KEY
# These are mapped to NEXT_PUBLIC versions in next.config.ts
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Postgres Configuration (from Vercel integration)
POSTGRES_URL=your_postgres_url
POSTGRES_PRISMA_URL=your_postgres_prisma_url
POSTGRES_URL_NON_POOLING=your_postgres_url_non_pooling
POSTGRES_USER=your_postgres_user
POSTGRES_HOST=your_postgres_host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=your_postgres_database

# App Specific Configuration
NEXT_PUBLIC_GUEST_ACCESS_CODE=MARIAGE2026
NEXT_PUBLIC_ADMIN_PASSWORD=admin2026
